/* 停车场列表页样式 */
page {
  background-color: #0D1117;
  min-height: 100vh;
}

.page-wrap {
  background-color: #0D1117;
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* ===== Header ===== */
.header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  padding: 80rpx 40rpx 40rpx;
  background: linear-gradient(180deg, #1A1A2E 0%, #0D1117 100%);
}

.header-title {
  display: block;
  font-size: 52rpx;
  font-weight: 700;
  color: #EAEAEA;
  letter-spacing: 2rpx;
  line-height: 1.2;
}

.header-sub {
  display: block;
  font-size: 24rpx;
  color: #6B7280;
  margin-top: 8rpx;
  letter-spacing: 4rpx;
}

.my-booking-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: #1E293B;
  border: 1rpx solid #334155;
  border-radius: 40rpx;
  padding: 16rpx 28rpx;
}

.btn-text {
  font-size: 26rpx;
  color: #94A3B8;
}

/* ===== 统计栏 ===== */
.stats-bar {
  display: flex;
  align-items: center;
  background: #161B27;
  border: 1rpx solid #1E293B;
  margin: 0 32rpx 32rpx;
  border-radius: 16rpx;
  padding: 28rpx 0;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #EAEAEA;
}

.available-num {
  color: #0F9B58;
}

.stat-label {
  font-size: 22rpx;
  color: #4B5563;
}

.stat-divider {
  width: 1rpx;
  height: 50rpx;
  background: #1E293B;
}

/* ===== 加载状态 ===== */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #1E293B;
  border-top-color: #E94560;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: #4B5563;
}

/* ===== 车场列表 ===== */
.lot-list {
  padding: 0 32rpx;
}

.lot-card {
  position: relative;
  display: flex;
  align-items: stretch;
  background: #161B27;
  border: 1rpx solid #1E293B;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  transition: all 0.2s;
}

.lot-card:active {
  transform: scale(0.98);
  border-color: #E94560;
}

/* 车场编号 */
.lot-index {
  width: 64rpx;
  background: #1E293B;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  color: #475569;
  writing-mode: vertical-lr;
  letter-spacing: 2rpx;
  flex-shrink: 0;
}

/* 主信息区 */
.lot-main {
  flex: 1;
  padding: 28rpx 24rpx;
  min-width: 0;
}

.lot-name-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.lot-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #E2E8F0;
  flex: 1;
  margin-right: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 状态徽章 */
.lot-status-badge {
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  flex-shrink: 0;
}

.status-available {
  background: rgba(15, 155, 88, 0.15);
  border: 1rpx solid rgba(15, 155, 88, 0.4);
}

.status-tight {
  background: rgba(245, 158, 11, 0.15);
  border: 1rpx solid rgba(245, 158, 11, 0.4);
}

.status-full {
  background: rgba(233, 69, 96, 0.15);
  border: 1rpx solid rgba(233, 69, 96, 0.4);
}

.badge-text {
  font-size: 22rpx;
  font-weight: 600;
}

.status-available .badge-text { color: #0F9B58; }
.status-tight .badge-text { color: #F59E0B; }
.status-full .badge-text { color: #E94560; }

/* 地址 */
.lot-address {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.addr-icon {
  font-size: 22rpx;
  color: #4B5563;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.addr-text {
  font-size: 24rpx;
  color: #6B7280;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 占用进度条 */
.occupancy-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.occupancy-bar {
  flex: 1;
  height: 6rpx;
  background: #1E293B;
  border-radius: 3rpx;
  overflow: hidden;
}

.occupancy-fill {
  height: 100%;
  border-radius: 3rpx;
  transition: width 0.5s ease;
}

.fill-available { background: #0F9B58; }
.fill-tight { background: #F59E0B; }
.fill-full { background: #E94560; }

.occupancy-text {
  font-size: 22rpx;
  color: #4B5563;
  flex-shrink: 0;
  width: 100rpx;
  text-align: right;
}

/* 底部信息 */
.lot-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.spots-info {
  display: flex;
  align-items: baseline;
}

.spots-available {
  font-size: 44rpx;
  font-weight: 700;
  color: #0F9B58;
  line-height: 1;
}

.spots-sep, .spots-unit {
  font-size: 24rpx;
  color: #4B5563;
}

.spots-total {
  font-size: 28rpx;
  color: #475569;
}

.lot-meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
}

.price-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #F59E0B;
}

.time-text {
  font-size: 22rpx;
  color: #4B5563;
}

/* 标签 */
.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tag {
  font-size: 20rpx;
  color: #64748B;
  background: #0F172A;
  border: 1rpx solid #1E293B;
  padding: 4rpx 14rpx;
  border-radius: 4rpx;
}

/* 右侧箭头 */
.lot-arrow {
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  font-size: 40rpx;
  color: #334155;
  flex-shrink: 0;
}

/* ===== 空状态 ===== */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  font-weight: 900;
  color: #1E293B;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #4B5563;
  margin-bottom: 12rpx;
}

.empty-sub {
  font-size: 24rpx;
  color: #374151;
}

/* ===== 底部提示 ===== */
.footer-tip {
  text-align: center;
  font-size: 22rpx;
  color: #374151;
  padding: 20rpx;
}
