<!-- 停车场列表页 -->
<view class="page-wrap">
  <!-- 顶部 Header -->
  <view class="header">
    <view class="header-left">
      <text class="header-title">停车预订</text>
      <text class="header-sub">选择车场 · 一键预位</text>
    </view>
    <view class="header-right" bindtap="onMyBookingsTap">
      <view class="my-booking-btn">
        <text class="iconfont icon-bookmark"></text>
        <text class="btn-text">我的预订</text>
      </view>
    </view>
  </view>

  <!-- 统计栏 -->
  <view class="stats-bar" wx:if="{{!loading && lots.length > 0}}">
    <view class="stat-item">
      <text class="stat-num">{{lots.length}}</text>
      <text class="stat-label">车场总数</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num available-num">{{lots.reduce ? '' : ''}}</text>
      <text class="stat-label">可用车场</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">实时</text>
      <text class="stat-label">数据更新</text>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-wrap" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">正在获取车场信息...</text>
  </view>

  <!-- 车场列表 -->
  <view class="lot-list" wx:if="{{!loading}}">
    <view
      class="lot-card"
      wx:for="{{lots}}"
      wx:key="_id"
      data-id="{{item._id}}"
      bindtap="onLotTap"
    >
      <!-- 车场编号标签 -->
      <view class="lot-index">P{{index + 1}}</view>

      <!-- 主信息区 -->
      <view class="lot-main">
        <view class="lot-name-row">
          <text class="lot-name">{{item.name}}</text>
          <view class="lot-status-badge status-{{item.statusClass}}">
            <text class="badge-text">{{item.statusText}}</text>
          </view>
        </view>

        <view class="lot-address">
          <text class="addr-icon">◎</text>
          <text class="addr-text">{{item.address}}</text>
        </view>

        <!-- 车位占用进度条 -->
        <view class="occupancy-wrap">
          <view class="occupancy-bar">
            <view
              class="occupancy-fill fill-{{item.statusClass}}"
              style="width: {{item.occupancyRate}}%"
            ></view>
          </view>
          <text class="occupancy-text">占用 {{item.occupancyRate}}%</text>
        </view>

        <!-- 底部信息 -->
        <view class="lot-footer">
          <view class="spots-info">
            <text class="spots-available">{{item.availableSpots}}</text>
            <text class="spots-sep"> / </text>
            <text class="spots-total">{{item.totalSpots}}</text>
            <text class="spots-unit"> 个可用</text>
          </view>
          <view class="lot-meta">
            <text class="price-text">¥{{item.pricePerHour}}/h</text>
            <text class="time-text">{{item.openTime}}-{{item.closeTime}}</text>
          </view>
        </view>

        <!-- 标签 -->
        <view class="tag-row" wx:if="{{item.tags && item.tags.length > 0}}">
          <text class="tag" wx:for="{{item.tags}}" wx:key="*this" wx:for-item="tag">{{tag}}</text>
        </view>
      </view>

      <!-- 右侧箭头 -->
      <view class="lot-arrow">›</view>
    </view>

    <!-- 空状态 -->
    <view class="empty-wrap" wx:if="{{lots.length === 0}}">
      <text class="empty-icon">P</text>
      <text class="empty-text">暂无可用车场</text>
      <text class="empty-sub">请稍后重试</text>
    </view>
  </view>

  <!-- 底部提示 -->
  <view class="footer-tip" wx:if="{{!loading && lots.length > 0}}">
    <text>车位数据实时更新 · 下拉可刷新</text>
  </view>
</view>
