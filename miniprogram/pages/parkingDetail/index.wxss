/* 车位详情页样式 */
page {
  background-color: #0D1117;
}

.page-wrap {
  background-color: #0D1117;
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* ===== 加载 ===== */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #1E293B;
  border-top-color: #E94560;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: #4B5563;
}

/* ===== 车场信息头部 ===== */
.lot-header {
  background: linear-gradient(180deg, #1A1A2E 0%, #161B27 100%);
  padding: 32rpx 40rpx;
  border-bottom: 1rpx solid #1E293B;
}

.lot-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.lot-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #E2E8F0;
  flex: 1;
}

.refresh-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #1E293B;
  border-radius: 50%;
}

.refresh-icon {
  font-size: 36rpx;
  color: #64748B;
}

.lot-address {
  font-size: 24rpx;
  color: #6B7280;
  margin-bottom: 28rpx;
}

/* 车位统计 */
.spot-stats {
  display: flex;
  gap: 0;
  background: #0F172A;
  border-radius: 16rpx;
  overflow: hidden;
  border: 1rpx solid #1E293B;
}

.stat-block {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  border-right: 1rpx solid #1E293B;
}

.stat-block:last-child {
  border-right: none;
}

.stat-num {
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.2;
  margin-bottom: 4rpx;
}

.stat-num.green { color: #0F9B58; }
.stat-num.red { color: #E94560; }
.stat-num.gray { color: #94A3B8; }
.stat-num.yellow { font-size: 26rpx; color: #F59E0B; }

.stat-label {
  font-size: 20rpx;
  color: #4B5563;
}

/* ===== 图例 ===== */
.legend-bar {
  display: flex;
  justify-content: center;
  gap: 32rpx;
  padding: 20rpx 40rpx;
  background: #0D1117;
  border-bottom: 1rpx solid #1A1A2E;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.legend-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 4rpx;
}

.dot-available { background: #0F9B58; }
.dot-reserved { background: #F59E0B; }
.dot-occupied { background: #E94560; }
.dot-disabled { background: #374151; }
.dot-vip { background: #7C3AED; border: 1rpx solid #A78BFA; }

.legend-text {
  font-size: 20rpx;
  color: #6B7280;
}

/* ===== 车位矩阵 ===== */
.spots-container {
  padding: 24rpx 24rpx 200rpx;
}

.row-section {
  margin-bottom: 32rpx;
}

.row-label {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.row-label-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #475569;
  background: #1E293B;
  padding: 6rpx 20rpx;
  border-radius: 6rpx;
  letter-spacing: 2rpx;
}

/* 车位网格 */
.spots-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.spot-cell {
  width: 96rpx;
  height: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 10rpx;
  position: relative;
  transition: all 0.15s;
}

.spot-cell:active {
  transform: scale(0.92);
}

/* 车位状态颜色 */
.spot-available {
  background: rgba(15, 155, 88, 0.15);
  border: 1rpx solid rgba(15, 155, 88, 0.5);
}

.spot-reserved {
  background: rgba(245, 158, 11, 0.15);
  border: 1rpx solid rgba(245, 158, 11, 0.4);
}

.spot-occupied {
  background: rgba(233, 69, 96, 0.12);
  border: 1rpx solid rgba(233, 69, 96, 0.3);
}

.spot-disabled {
  background: #111827;
  border: 1rpx solid #1F2937;
}

/* VIP 车位 */
.spot-vip-type.spot-available {
  background: rgba(124, 58, 237, 0.15);
  border: 1rpx solid rgba(124, 58, 237, 0.5);
}

.spot-no {
  font-size: 18rpx;
  font-weight: 600;
  line-height: 1.2;
}

.spot-available .spot-no { color: #0F9B58; }
.spot-reserved .spot-no { color: #F59E0B; }
.spot-occupied .spot-no { color: #E94560; }
.spot-disabled .spot-no { color: #374151; }
.spot-vip-type.spot-available .spot-no { color: #A78BFA; }

.spot-type-label {
  position: absolute;
  top: 4rpx;
  right: 6rpx;
  font-size: 16rpx;
  font-weight: 700;
  color: #A78BFA;
}

/* ===== 预订面板 ===== */
.booking-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 100;
}

.booking-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #161B27;
  border-top: 1rpx solid #1E293B;
  border-radius: 32rpx 32rpx 0 0;
  padding: 0 40rpx 60rpx;
  z-index: 101;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.32, 0.72, 0, 1);
}

.panel-show {
  transform: translateY(0);
}

.panel-handle {
  width: 60rpx;
  height: 6rpx;
  background: #334155;
  border-radius: 3rpx;
  margin: 20rpx auto 32rpx;
}

.panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.panel-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #E2E8F0;
}

.panel-close {
  font-size: 32rpx;
  color: #64748B;
  padding: 8rpx;
}

/* 选中车位信息 */
.selected-spot-info {
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: #0F172A;
  border: 1rpx solid #1E293B;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
}

.spot-badge {
  width: 80rpx;
  height: 80rpx;
  background: rgba(15, 155, 88, 0.2);
  border: 2rpx solid #0F9B58;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.spot-badge-no {
  font-size: 22rpx;
  font-weight: 700;
  color: #0F9B58;
}

.spot-detail-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #E2E8F0;
  margin-bottom: 6rpx;
}

.spot-detail-type {
  font-size: 24rpx;
  color: #64748B;
}

/* 时长选择 */
.hours-section {
  margin-bottom: 28rpx;
}

.section-label {
  display: block;
  font-size: 26rpx;
  color: #94A3B8;
  margin-bottom: 16rpx;
}

.hours-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.hours-item {
  width: 120rpx;
  height: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #0F172A;
  border: 1rpx solid #1E293B;
  border-radius: 12rpx;
  transition: all 0.15s;
}

.hours-active {
  background: rgba(233, 69, 96, 0.15);
  border-color: #E94560;
}

.hours-num {
  font-size: 32rpx;
  font-weight: 700;
  color: #94A3B8;
  line-height: 1;
}

.hours-active .hours-num {
  color: #E94560;
}

.hours-unit {
  font-size: 18rpx;
  color: #4B5563;
  margin-top: 4rpx;
}

.hours-active .hours-unit {
  color: #E94560;
}

/* 费用区域 */
.fee-section {
  background: #0F172A;
  border: 1rpx solid #1E293B;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
}

.fee-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
}

.fee-total-row {
  border-top: 1rpx solid #1E293B;
  margin-top: 12rpx;
  padding-top: 20rpx;
}

.fee-label {
  font-size: 26rpx;
  color: #64748B;
}

.fee-value {
  font-size: 26rpx;
  color: #94A3B8;
}

.fee-total-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #E2E8F0;
}

.fee-total-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #F59E0B;
}

/* 确认按钮 */
.confirm-btn {
  background: #E94560;
  border-radius: 16rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  transition: all 0.15s;
}

.confirm-btn:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.btn-loading {
  opacity: 0.6;
}

.confirm-btn-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 4rpx;
}

.panel-tip {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: #374151;
}
