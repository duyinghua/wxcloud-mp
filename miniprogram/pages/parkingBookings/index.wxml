<!-- 我的预订页 -->
<view class="page-wrap">
  <!-- 顶部 Tab -->
  <view class="tab-bar">
    <view
      class="tab-item {{activeTab === 'active' ? 'tab-active' : ''}}"
      data-tab="active"
      bindtap="onTabSwitch"
    >
      <text class="tab-text">进行中</text>
      <view class="tab-badge" wx:if="{{activeBookings.length > 0}}">
        <text class="badge-num">{{activeBookings.length}}</text>
      </view>
    </view>
    <view
      class="tab-item {{activeTab === 'history' ? 'tab-active' : ''}}"
      data-tab="history"
      bindtap="onTabSwitch"
    >
      <text class="tab-text">历史记录</text>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-wrap" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载预订记录...</text>
  </view>

  <!-- 进行中的预订 -->
  <view class="booking-list" wx:if="{{!loading && activeTab === 'active'}}">
    <view
      class="booking-card active-card"
      wx:for="{{activeBookings}}"
      wx:key="_id"
    >
      <!-- 卡片头 -->
      <view class="card-header">
        <view class="card-lot-name">{{item.lotName}}</view>
        <view class="status-badge status-{{item.status}}">
          <text class="status-text">{{item.statusText}}</text>
        </view>
      </view>

      <!-- 车位号 -->
      <view class="spot-display">
        <view class="spot-number-block">
          <text class="spot-number">{{item.spotNo}}</text>
          <text class="spot-label">车位号</text>
        </view>
        <view class="booking-time-block">
          <view class="time-row">
            <text class="time-icon">▶</text>
            <text class="time-val">{{item.startTimeStr}}</text>
          </view>
          <view class="time-connector"></view>
          <view class="time-row">
            <text class="time-icon">■</text>
            <text class="time-val">{{item.endTimeStr}}</text>
          </view>
        </view>
      </view>

      <!-- 地址 -->
      <view class="card-address">◎ {{item.lotAddress}}</view>

      <!-- 底部信息 -->
      <view class="card-footer">
        <view class="fee-info">
          <text class="fee-label">预估费用</text>
          <text class="fee-amount">¥{{item.totalFee}}</text>
        </view>
        <view
          class="cancel-btn {{cancellingId === item._id ? 'btn-cancelling' : ''}}"
          data-id="{{item._id}}"
          bindtap="onCancelTap"
        >
          <text class="cancel-text">取消预订</text>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-wrap" wx:if="{{activeBookings.length === 0}}">
      <text class="empty-icon-text">P</text>
      <text class="empty-title">暂无进行中的预订</text>
      <text class="empty-sub">去选择一个停车场开始预订吧</text>
      <view class="go-book-btn" bindtap="onGoBook">
        <text>去预订</text>
      </view>
    </view>
  </view>

  <!-- 历史记录 -->
  <view class="booking-list" wx:if="{{!loading && activeTab === 'history'}}">
    <view
      class="booking-card history-card"
      wx:for="{{historyBookings}}"
      wx:key="_id"
    >
      <view class="card-header">
        <view class="card-lot-name">{{item.lotName}}</view>
        <view class="status-badge status-{{item.status}}">
          <text class="status-text">{{item.statusText}}</text>
        </view>
      </view>

      <view class="history-info-row">
        <view class="history-spot">
          <text class="h-label">车位</text>
          <text class="h-value">{{item.spotNo}}</text>
        </view>
        <view class="history-time">
          <text class="h-label">预订时间</text>
          <text class="h-value">{{item.createTimeStr}}</text>
        </view>
        <view class="history-fee">
          <text class="h-label">费用</text>
          <text class="h-value fee-color">¥{{item.totalFee}}</text>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-wrap" wx:if="{{historyBookings.length === 0}}">
      <text class="empty-icon-text">H</text>
      <text class="empty-title">暂无历史记录</text>
    </view>
  </view>
</view>
